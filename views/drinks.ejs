<html>
    <head>
        <title><%= title %></title>
        <link rel="stylesheet" href="/styles.css">
    </head>
    <body>
        <%- include('navbar', {links: links}) %>
         <h2><%= title %></h2>
            <ul>
                <% list.forEach((item) => { %>
                    <li>
                        <%= item.name %>
                        <a href="/drinks/<%= item.id %>">View</a>
                        <a href="/drinks/<%= item.id %>/update">Update</a>
                        <form action="/drinks/<%= item.id %>/delete" method="POST" style="display:inline">
                            <button type="submit" onclick="return confirm('Are you sure you want to delete this drink?');">
                                Delete
                            </button>
                        </form>
                    </li>
                <% }); %>
            </ul>
        <a href="/drinks/create">Create a drink</a>
    </body>
</html>
<html>
    <head>
        <title><%= title %></title>
        <link rel="stylesheet" href="/styles.css">
    </head>
    <body>
        <%- include('navbar', {links: links}) %>
         <h2><%= title %></h2>
            <ul>
                <% list.forEach((item) => { %>
                    <li>
                        <%= item.name %>
                        <a href="/snacks/<%= item.id %>">View</a>
                        <% if (locals.currentUser!== undefined) { %>
                            <% if (locals.currentUser.username == 'admin') { %>
                                <a href="/snacks/<%= item.id %>/update">Update</a>
                                <form action="/snacks/<%= item.id %>/delete" method="POST" style="display:inline">
                                    <button type="submit" onclick="return confirm('Are you sure you want to delete this snack?');">
                                        Delete
                                    </button>
                                </form>
                            <% } %>
                        <% } %>
                    </li>
                <% }); %>
            </ul>
            <% if (locals.currentUser!== undefined) { %>
                <% if (locals.currentUser.username == 'admin') { %>
                    <a href="/snacks/create">Create a snack</a>
                <% } %>
            <% } %>
    </body>
</html>